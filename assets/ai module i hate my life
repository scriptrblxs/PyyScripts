-------------------------------------------------------------------------------
--[[
    local code = "XYZ123" -- Your short code
    local raw = GetCompressedJsonFromCode(code)
    if raw then
        local data = DecompressToTable(raw)
        
        -- If data contains multiple objects, you'd loop through them here.
        -- Assuming 'data.Objects[1]' is a rig track and 'data.Hierarchy' exists:
        
        local myKFS = CreateKeyframeSequence({
            Name = data.Name,
            FPS = data.FPS,
            Hierarchy = data.Objects[1].Hierarchy, -- This depends on your specific JSON structure
            Tracks = data.Objects[1].Tracks
        })
        
        myKFS.Parent = workspace
    end
]]

return {GetCompressedJsonFromCode=GetCompressedJsonFromCode,DecompressToTable=DecompressToTable,CreateKeyframeSequence=CreateKeyframeSequence}
